# Production Environment Variables
# These must be set in Vercel Project Settings > Environment Variables
# 
# IMPORTANT: Set VITE_API_URL to your deployed backend URL in Vercel Dashboard
# Examples:
# - If backend is on Vercel: https://swigato-backend.vercel.app
# - If backend is on custom domain: https://api.swigato.com
# - If backend is on another host: https://your-backend-url.com
# 
# Leave empty here - it will be overridden by Vercel's environment variables
VITE_API_URL=
